{
  "$schema": "https://raw.githubusercontent.com/nicktrav/tauri-docs-refs/refs/heads/main/tauri.conf.v2.json",
  "productName": "Uintas",
  "version": "0.1.0",
  "identifier": "com.jedwood.uintas",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Uintas",
        "width": 1200,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
