#!/bin/bash
#
# Version-controlled pre-commit hook. Enable it once per clone with:
#     git config core.hooksPath .githooks
#
# It does two things:
#   1. Bumps the PWA cache version so installed home-screen apps pick up changes.
#   2. Whenever uinta_lakes.db is staged, regenerates the artifacts derived from
#      it so they can never silently drift from the DB:
#        - data/seeds/      reproducible CSV source (scripts/export_seeds.py)
#        - lakes_data.json  the JSON the PWA loads  (scripts/export_web_data.py)

set -e

# 1. PWA cache version
NEW_VERSION="uintas-v$(date +%s)"
sed -i '' "s/uintas-v[0-9]*/${NEW_VERSION}/g" service-worker.js
git add service-worker.js
echo "PWA cache version updated to: ${NEW_VERSION}"

# 2. Keep DB-derived artifacts in lockstep with the DB being committed
if git diff --cached --name-only | grep -qx 'uinta_lakes.db'; then
    echo "uinta_lakes.db staged — regenerating data/seeds/ and lakes_data.json ..."
    python3 scripts/export_seeds.py
    python3 scripts/export_web_data.py
    git add data/seeds/ lakes_data.json
fi
